# Solar Rota Backend — Ortam Değişkenleri Şablonu
# Bu dosyayı `.env` olarak kopyalayın ve production'da gerçek değerlerle doldurun.
# `.env` dosyası git'e commit edilmez (.gitignore'a ekleyin).

# ── API Key Authentication ───────────────────────────────────────────────────
# Boş bırakılırsa → dev-mode, auth atlanır (yalnızca localhost'ta çalışırken)
# Production için: openssl rand -hex 32
SOLARROTA_API_KEY=

# Replay koruması penceresi (ms). Varsayılan: 30000 (30 saniye)
SOLARROTA_REPLAY_WINDOW_MS=30000

# ── CORS ────────────────────────────────────────────────────────────────────
# Virgülle ayrılmış izin verilen origin'ler
# CORS_ORIGINS=https://app.solarrota.com,https://solarrota.com

# Origin regex (localhost geliştirme için varsayılan aktif)
# CORS_ORIGIN_REGEX=^https://.*\.solarrota\.com$
