{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Solar Rota financial assumptions",
  "type": "object",
  "required": ["version", "market", "currency", "sourceDate", "modelLabel", "financialProfiles"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "market": { "type": "string", "minLength": 1 },
    "currency": { "type": "string", "enum": ["TRY"] },
    "sourceDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "modelLabel": { "type": "string", "minLength": 1 },
    "financialProfiles": {
      "type": "object",
      "required": ["conservative", "base", "optimistic", "custom"],
      "additionalProperties": { "$ref": "#/$defs/financialProfile" }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "required": ["sourceDate", "sourceLabel", "confidence"],
      "properties": {
        "sourceDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "sourceLabel": { "type": "string", "minLength": 1 },
        "confidence": { "type": "string", "enum": ["low", "low-medium", "medium", "medium-high", "high"] }
      }
    },
    "curveSegment": {
      "type": "object",
      "required": ["fromYear", "toYear", "rate"],
      "properties": {
        "fromYear": { "type": "integer", "minimum": 1 },
        "toYear": { "type": "integer", "minimum": 1 },
        "rate": { "type": "number", "minimum": -0.5, "maximum": 2 }
      }
    },
    "financialProfile": {
      "allOf": [
        { "$ref": "#/$defs/metadata" },
        {
          "type": "object",
          "required": ["discountRate", "tariffIncreaseCurve"],
          "properties": {
            "discountRate": { "type": "number", "minimum": 0, "maximum": 2 },
            "tariffIncreaseCurve": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/curveSegment" }
            }
          }
        }
      ]
    }
  }
}
