# Solar Rota Backend — Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# cp .env.example .env

# ── Auth ─────────────────────────────────────────────────────────────────────
# Production'da mutlaka set edilmeli. Boş bırakılırsa dev-mode: auth atlanır.
SOLARROTA_API_KEY=

# Replay saldırısına karşı kabul edilen azami zaman farkı (ms). Varsayılan: 30 s.
SOLARROTA_REPLAY_WINDOW_MS=30000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Boş bırakılırsa aşağıdaki varsayılanlar kullanılır.
# Format: <istek_sayısı>/<periyot>  — periyot: second | minute | hour | day
RATE_LIMIT_PV_CALCULATE=10/minute
RATE_LIMIT_PVLIB_CALCULATE=10/minute
RATE_LIMIT_FINANCIAL=20/minute
RATE_LIMIT_PVGIS_PROXY=5/minute
RATE_LIMIT_FIELD_IMPORT=5/minute
RATE_LIMIT_PANEL_THERMAL=30/minute

# Test/geliştirme ortamında tüm limitleri devre dışı bırakmak için:
# RATE_LIMIT_DISABLED=true

# ── CORS ─────────────────────────────────────────────────────────────────────
# Virgülle ayrılmış izin verilen origin listesi.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Opsiyonel ─────────────────────────────────────────────────────────────────
# Reverse proxy arkasındaysa X-Forwarded-For başlığına güvenmek için:
# FORWARDED_ALLOW_IPS=*
